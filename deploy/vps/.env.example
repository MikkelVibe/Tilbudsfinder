APP_NAME=Tilbudsfinder
APP_ENV=production
APP_KEY=base64:replace-with-production-key
APP_DEBUG=false
APP_URL=https://replace-with-domain

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=tilbudsfinder
DB_USERNAME=tilbudsfinder
DB_PASSWORD=replace-with-strong-password

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS=alerts@replace-with-domain
MAIL_FROM_NAME="${APP_NAME}"

TILBUDSFINDER_IMAGE=ghcr.io/mikkelvibe/tilbudsfinder:latest
SCRAPER_AGENT_VERSION=replace-with-image-sha
